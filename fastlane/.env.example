# App Store Connect API キーの設定例。
# この内容を fastlane/.env にコピーして自分の値を入れる（.env は gitignore）。
#
# キーの作り方:
#   App Store Connect → Users and Access → Integrations → App Store Connect API
#   → ＋で「キー」を作成（Role: App Manager 以上）→ .p8 をダウンロード（再DL不可）。
#   Issuer ID は同ページ上部、Key ID は作成したキーの行に表示される。

# 作成したキーの Key ID（例: ABCD123456）
ASC_KEY_ID=

# Issuer ID（UUID 形式）
ASC_ISSUER_ID=

# ダウンロードした .p8 ファイルへのパス（リポジトリ外に置く）
# 例: ~/.appstoreconnect/private_keys/AuthKey_ABCD123456.p8
ASC_KEY_PATH=
